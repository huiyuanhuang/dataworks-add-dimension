async def _check_all_upstream_columns(upstreams, dimension_name, default_project):
    """Run all upstream DDL checks in parallel using ThreadPoolExecutor."""
    loop = asyncio.get_event_loop()
    tasks = []
    
    for t in upstreams:
        table_name = t.get("table_name", "")
        if not table_name:
            continue
        coro = loop.run_in_executor(
            None, check_column_in_table,
            table_name, dimension_name, default_project
        )
        tasks.append((t, coro))
    
    results = await asyncio.gather(*[c for _, c in tasks], return_exceptions=True)
    
    for (t, _), result in zip(tasks, results):
        table_name = t.get("table_name", "")
        if isinstance(result, Exception):
            t["field_exists"] = False
            t["ddl_verified"] = False
            yield t, {"exists": False, "error": str(result)}
        else:
            t["field_exists"] = result["exists"]
            t["ddl_verified"] = True
            yield t, result

