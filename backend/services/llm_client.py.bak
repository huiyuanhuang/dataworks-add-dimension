"""OpenAI API client for SQL analysis, rewriting, and self-checking.

Optimizations applied:
- Tool Use: structured output via JSON mode (eliminates JSON parse failures)
- Model Tiering: gpt-5.4 for all tasks
- Streaming: reduce perceived latency
- Result Caching: in-memory cache to avoid duplicate LLM calls
"""

import json
import logging
import os
import re
import time
import hashlib
from typing import Optional

try:
    import openai
except ImportError:
    openai = None

logger = logging.getLogger("llm_client")

# ── Environment config ──────────────────────────────────────────
OPENAI_API_KEY = os.environ.get("OPENAI_API_KEY", os.environ.get("ANTHROPIC_AUTH_TOKEN", ""))
OPENAI_BASE_URL = os.environ.get("OPENAI_BASE_URL", os.environ.get("ANTHROPIC_BASE_URL", ""))
OPENAI_MODEL = os.environ.get("OPENAI_MODEL", "gpt-5.4")
OPENAI_TIMEOUT = int(os.environ.get("OPENAI_TIMEOUT", os.environ.get("ANTHROPIC_TIMEOUT", "60")))
OPENAI_MAX_RETRIES = int(os.environ.get("OPENAI_MAX_RETRIES", os.environ.get("ANTHROPIC_MAX_RETRIES", "3")))

# ── Prompt constants ────────────────────────────────────────────

ANALYZE_SYSTEM_PROMPT = """You are an ODPS (MaxCompute) SQL analyst. You analyze SQL scripts \
to determine how they expand dimensions for reporting dashboards. ODPS SQL uses Alibaba Cloud \
MaxCompute dialect (similar to Hive SQL).

When given a SQL script and a new dimension name, you must:
1. Identify the expansion type: "cube" (GROUP BY CUBE), "lateral_view" (LATERAL VIEW EXPLODE), \
"group_by" (plain GROUP BY without CUBE or EXPLODE), or "unknown" if none found.
2. Parse all upstream source tables (tables referenced in FROM/JOIN clauses, \
excluding the INSERT OVERWRITE target table).
3. For each upstream table, determine how the dimension field relates to the current SQL output.
4. Identify any issues that would prevent adding the dimension.

Use the sql_analysis tool to report your findings."""

ANALYZE_USER_TEMPLATE = """Analyze this ODPS SQL for adding the dimension "{dimension_name}" \
(Chinese name: "{dimension_chinese_name}").

SQL:
```sql
{original_sql}
```"""

REWRITE_SYSTEM_PROMPT = """You are an ODPS (MaxCompute) SQL rewriting expert. You modify SQL \
scripts to add new dimension columns for reporting dashboards. ODPS SQL uses Alibaba Cloud \
MaxCompute dialect (similar to Hive SQL).

CRITICAL RULES for dimension addition:

1. For CUBE expansion (GROUP BY CUBE):
   - Add IF(grouping({dim}) = 0,{dim},'ALL') AS {dim} to the INNER SELECT that contains the \
GROUP BY CUBE clause, as the LAST item in the SELECT column list (after all existing \
columns including aggregate expressions like SUM/COUNT, immediately before FROM).
   - Add the plain column reference {dim} (NOT nvl/coalesce) to the OUTERmost SELECT, \
as the LAST item in the SELECT column list (after all existing columns including \
aggregate expressions). The ALL values are already produced by IF(grouping()) in \
the inner query, so the outer SELECT just references the column directly.
   - Add {dim} to the GROUP BY CUBE(...) dimension list inside the parentheses.
   - Add {dim} to the OUTER GROUP BY clause (the one WITHOUT CUBE, which aggregates \
the CUBE subquery results).
   - Add {dim} to the INSERT OVERWRITE TABLE column list (if explicit columns are listed).
   - Add {dim} STRING COMMENT '{chinese_name}' to the CREATE TABLE column definition \
(if present), as the last column before the closing parenthesis.
   - Insert ALTER TABLE ADD COLUMNS statement after CREATE TABLE closing, wrapped in \
-- CODEX:BEGIN_MANAGED_ALTER and -- CODEX:END_MANAGED_ALTER markers.

2. For LATERAL VIEW EXPLODE expansion:
   - Add a new LATERAL VIEW EXPLODE(array({dim}, 'ALL')) line after the existing \
LATERAL VIEW EXPLODE line, with a derived alias table and group column.
   - Add the group column to the SELECT list as the LAST item (after all existing columns).
   - Add {dim} to INSERT OVERWRITE TABLE column list and CREATE TABLE definition.
   - Generate ALTER TABLE ADD COLUMNS statement with CODEX markers.

3. For plain GROUP BY expansion:
   - Add {dim} AS {dim} to the SELECT list as the LAST item (after all existing columns, \
including aggregate expressions like SUM/COUNT, immediately before FROM).
   - Add {dim} to the GROUP BY clause.
   - Add {dim} to INSERT OVERWRITE TABLE column list and CREATE TABLE definition.
   - Generate ALTER TABLE ADD COLUMNS statement with CODEX markers.

4. ALWAYS:
   - Preserve ALL existing SQL structure, comments, and formatting exactly as-is.
   - Only ADD new elements, never DELETE or REORDER existing ones.
   - The new dimension column MUST be the LAST column in every clause where it is added:
     SELECT column list, INSERT OVERWRITE TABLE column list, CREATE TABLE column \
definition, and GROUP BY dimension list. NEVER place the new dimension column in the \
middle of a SELECT list (e.g. between existing dimension columns and aggregate columns). \
It MUST always come AFTER all existing columns, including aggregate expressions like \
SUM/COUNT/AVG. This is the single most important positional rule.
   - Use the dimension Chinese name as COMMENT value where applicable.
   - For ALTER TABLE, use the format: \
ALTER TABLE <target_table> ADD COLUMNS ({dim} STRING COMMENT '{chinese_name}');
   - Wrap the ALTER TABLE in -- CODEX:BEGIN_MANAGED_ALTER and -- CODEX:END_MANAGED_ALTER.

Use the sql_rewrite tool to report the modified SQL and changes."""

REWRITE_USER_TEMPLATE = """Rewrite this ODPS SQL to add dimension "{dimension_name}" \
(Chinese name: "{dimension_chinese_name}").
The expansion type is: {expansion_type}.

Original SQL:
```sql
{original_sql}
```

Apply all the dimension addition rules for the {expansion_type} expansion type."""

SELF_CHECK_SYSTEM_PROMPT = """You are an ODPS SQL quality checker. You verify that dimension \
additions to SQL scripts are correct and complete.

Given the original SQL, modified SQL, dimension name, expansion type, and ALTER TABLE SQL, \
check each of the following criteria:

1. column_position: Is the new dimension the LAST column in the INSERT OVERWRITE TABLE \
column list? If there is no explicit column list, check if the dimension appears in the \
outer SELECT as the last non-aggregate column.
2. all_logic:
   - For CUBE: does the modified SQL contain IF(grouping({dim})...) in the inner subquery?
   - For lateral_view: does it contain EXPLODE(array({dim}, 'ALL'))?
   - For group_by: always passes (no ALL logic needed).
3. dimension_in_select: Is {dim} present in the outermost SELECT clause?
4. dimension_in_groupby: Is {dim} present in GROUP BY or GROUP BY CUBE?
5. dimension_in_outer_groupby: (CUBE only) Is {dim} in the outer GROUP BY \
(the one without CUBE)?
6. alter_table: Is the ALTER TABLE ADD COLUMNS statement (provided separately) \
present and correct?
7. managed_blocks: Always passes — CODEX markers are stripped from the modified SQL \
and the ALTER TABLE is handled separately via the alter_table_sql field.

Use the sql_self_check tool to report the check results."""

SELF_CHECK_USER_TEMPLATE = """Self-check this SQL modification.

Original SQL:
```sql
{original_sql}
```

Modified SQL:
```sql
{modified_sql}
```

Dimension: {dimension_name}
Expansion type: {expansion_type}
ALTER TABLE SQL: {alter_sql}

Verify all criteria."""


